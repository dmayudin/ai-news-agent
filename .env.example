# OpenAI API Key
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefgh

# Telegram User ID (для отправки личных сообщений)
TELEGRAM_USER_ID=123456789

# Telegram Channel ID (для публикации постов)
CHANNEL_ID=@your_channel_name

# WebApp URL (URL вашего Mini App)
WEBAPP_URL=https://your-domain.com

# Cloudflare Tunnel Token (для HTTPS)
CF_TUNNEL_TOKEN=eyJhIjoi...

# Аутентификация для WebApp
APP_USERNAME=admin
APP_PASSWORD=your_secure_password
FLASK_SECRET_KEY=your_random_secret_key_here

# VPN конфигурация (если используется)
# VPN_ENABLED=true
# VPN_CONFIG_PATH=/etc/wireguard/wg0.conf
